{"id":"structured-json-001","category":"structured_json","task":"Return only strict JSON with keys decision, rationale, and steps. Use decision \"defer\" because the migration has no rollback plan. Include at least two steps and mention rollback in rationale.","constraints":["Strict JSON only","decision must be defer","rationale mentions rollback"],"grader":{"json":{"requireValid":true,"requiredPaths":["decision","rationale","steps[0]"],"equals":{"decision":"defer"},"includes":{"rationale":"rollback"},"arrayMinLength":{"steps":2}}},"difficulty":"easy"}
