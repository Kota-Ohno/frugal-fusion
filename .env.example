# Copy this file to `.env` (gitignored) and fill in the values.
# The CLI loads `.env` automatically at startup; real shell exports take
# precedence over file values.

# Required for `models`, `ask`, and live `eval` runs. Get one at:
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional. Only needed for HMAC-bound case manifests / private holdout claim
# gates. The flag is `--manifest-hmac-key-env <NAME>`; default name shown here.
# FRUGAL_FUSION_MANIFEST_HMAC_KEY=
